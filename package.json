{
  "name": "lanflare",
  "version": "1.0.0",
  "description": "LAN file transfer & shared clipboard app",
  "author": "LanFlare <quyansiyuanwang@qq.com>",
  "main": "dist/main.js",
  "scripts": {
    "tsc": "tsc",
    "tsc:check": "tsc --noEmit",
    "lint": "eslint . --fix --ext .ts --cache",
    "lint:check": "eslint . --ext .ts --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "npm run tsc && npm run lint && npm run format",
    "copyassets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/src/assets',{recursive:true});fs.copyFileSync('src/assets/web-receiver.html','dist/src/assets/web-receiver.html');\"",
    "start": "tsc && npm run copyassets && electron .",
    "dev": "tsc && npm run copyassets && electron .",
    "build": "tsc && npm run copyassets && electron-builder",
    "build:win": "tsc && npm run copyassets && electron-builder --win",
    "build:mac": "tsc && npm run copyassets && electron-builder --mac",
    "build:linux": "tsc && npm run copyassets && electron-builder --linux",
    "build:all": "tsc && npm run copyassets && electron-builder --win --linux --mac"
  },
  "build": {
    "appId": "com.lanflare.app",
    "productName": "LanFlare",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/main.js",
      "dist/src/**/*",
      "src/renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "artifactName": "${productName}-${version}-Linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "artifactName": "${productName}-${version}-Windows-${arch}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Windows-${arch}-Portable.${ext}"
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
