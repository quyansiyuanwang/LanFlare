{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "declaration": false,
    "removeComments": true,
    "importHelpers": false,
    "downlevelIteration": false
  },
  "include": ["main.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "renderer", "scripts"]
}
